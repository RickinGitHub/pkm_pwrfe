# Copy to .env and fill in
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-5-20250929

# Embedding: set to a sentence-transformers model for semantic search
# Leave empty or set to "pseudo" for deterministic hash-based fallback
# Examples: all-MiniLM-L6-v2 (384-dim, fast), all-mpnet-base-v2 (768-dim, accurate)
EMBEDDING_MODEL=

# Chunking: split large documents for fine-grained retrieval
# Set to "1" or "true" to enable paragraph-based chunking
CORPUS_CHUNK_ENABLED=1
CORPUS_CHUNK_SIZE=1200
CORPUS_CHUNK_OVERLAP=150

# Paths
CACHE_EMBEDDING_MODEL=local-hashing
LONG_TERM_DB_PATH=memories/long_term.db
SHORT_TERM_PATH=memories/short_term.json
ROUTING_CONFIG=config/routing.yaml
RULES_CONFIG=config/rules.yaml
CACHE_PATH=memories/cache.db

# Watcher Pipeline
WATCHER_DIR=rag/corpus
WATCHER_DEBOUNCE_MS=500
WATCHER_LOG_LEVEL=INFO
FTS_INDEX_PATH=rag/fts_index.db
TAG_RULES_CONFIG=config/tag_rules.yaml
INDEX_YAML_PATH=config/index.yaml

# Phase 5: Review skill — LLM cache DB for 24h domain+query reuse
# Default: memories/review_cache.db (set to override for test isolation)
# REVIEW_CACHE_DB=memories/review_cache.db

# Phase 6: Reflect skill — dedup window (hours) for same insight text
REFLECT_DEDUP_WINDOW_HOURS=24

# Phase 7: Pipeline chunk-level L5 index (Phase 7)
PIPELINE_CHUNK_ENABLED=1
PIPELINE_CHUNK_SIZE=1200
PIPELINE_CHUNK_OVERLAP=150

# Phase 7: Offline Ollama classifier (optional, disabled by default)
# Set OLLAMA_CLASSIFY_ENABLED=1 to enable rules → Ollama fallback in pipeline
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_CLASSIFY_TIMEOUT=30
OLLAMA_CLASSIFY_ENABLED=0
